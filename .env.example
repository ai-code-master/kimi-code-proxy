# Kimi Code OAuth Proxy Configuration
# Copy this file to .env and fill in your values.

# Required: OAuth client ID (get from Kimi CLI or browser dev tools)
KCP_CLIENT_ID=your_client_id_here

# Optional: override default paths
# KCP_CREDENTIALS_PATH=~/.kimi/credentials/kimi-code.json
# KCP_DEVICE_ID_PATH=~/.kimi/device_id

# Optional: override endpoints
# KCP_AUTH_ENDPOINT=https://auth.kimi.com/api/oauth/token
# KCP_UPSTREAM_BASE=https://api.kimi.com/coding

# Optional: server settings
# KCP_HOST=127.0.0.1
# KCP_PORT=8765
# KCP_MAX_CONCURRENT=4
# KCP_RPM_LIMIT=20
# KCP_MAX_RETRIES=2

# Optional: timeouts (seconds)
# KCP_UPSTREAM_TIMEOUT=600
# KCP_QUEUE_TIMEOUT=300

# Optional: logging
# KCP_LOG_DIR=~/.hermes/logs
# KCP_LOG_MAX_BYTES=10485760
# KCP_LOG_BACKUP_COUNT=3
# KCP_LOG_DIR_MAX_BYTES=524288000

# Optional: thresholds
# KCP_SLOW_REQUEST_THRESHOLD=30.0
# KCP_GRACEFUL_SHUTDOWN_WAIT=30

# Optional: debug
# KCP_DEBUG_BODY=false

# Optional: device info (override to hide real machine name)
# KCP_DEVICE_NAME=KimiProxy
# KCP_DEVICE_MODEL=Desktop
# KCP_DEVICE_PLATFORM=macOS
# KCP_DEVICE_VERSION=2.1.153
# KCP_OS_VERSION=15.0
