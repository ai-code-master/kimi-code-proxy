<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.github.YOUR_USERNAME.kimi-code-proxy</string>

    <key>ProgramArguments</key>
    <array>
        <string>/PATH/TO/python3</string>
        <string>/ABSOLUTE/PATH/TO/kimi_code_proxy.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/kimi-code-proxy</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/YOUR_USERNAME</string>
        <!-- Load .env automatically since the script reads it -->
    </dict>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/kimi-code-proxy.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/kimi-code-proxy.log</string>
</dict>
</plist>
